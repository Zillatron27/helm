{
  "name": "@27bit/helm",
  "version": "0.10.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./renderer/*": "./src/renderer/*",
    "./data/*": "./src/data/*",
    "./state": "./src/ui/state.ts",
    "./theme": "./src/ui/theme.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "typecheck:all": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json"
  },
  "dependencies": {
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
